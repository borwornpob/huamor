PORT=8787
DATABASE_URL=
TRUST_FORWARDED_USER_HEADERS=false
JWT_SECRET=change-me-in-production
PDF_DATA_DIR=./data/pdfs

# Qdrant self-hosted (primary retrieval source)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=medical_kb
QDRANT_TEXT_PAYLOAD_KEY=text
QDRANT_VECTOR_NAME=
QDRANT_SCORE_THRESHOLD=0

# Query embedding provider for vector search
EMBEDDING_PROVIDER=huggingface
EMBEDDING_MODEL=BAAI/bge-m3
HUGGINGFACE_API_KEY=
HUGGINGFACE_BASE_URL=https://api-inference.huggingface.co/models

# Chat LLM provider
LLM_PROVIDER=sealion
LLM_TEMPERATURE=0.1
SEALION_API_KEY=
SEALION_BASE_URL=https://api.sea-lion.ai/v1
SEALION_MODEL=aisingapore/Gemma-SEA-LION-v4-27B-IT

# Local sentence-transformers mode
# EMBEDDING_PROVIDER=sentence-transformers
# PYTHON_EXECUTABLE=python3
# SENTENCE_TRANSFORMERS_SCRIPT=./scripts/embed_query.py
# SENTENCE_TRANSFORMERS_TIMEOUT_MS=120000
