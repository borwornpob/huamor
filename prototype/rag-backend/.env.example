APP_ENV=dev
PORT=8787
PUBLIC_BASE_URL=http://localhost:8787
JWT_SECRET=change-me
ALLOW_DEMO_USERS=true
STRICT_STARTUP=false
METRICS_ENABLED=true

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/huamor
TRUST_FORWARDED_USER_HEADERS=false

QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=medical_kb
QDRANT_API_KEY=
QDRANT_TEXT_PAYLOAD_KEY=text
QDRANT_VECTOR_NAME=
QDRANT_SCORE_THRESHOLD=0
ACTIVE_INDEX_VERSION=medical_kb

EMBEDDING_PROVIDER=sentence-transformers
EMBEDDING_MODEL=BAAI/bge-m3
HUGGINGFACE_API_KEY=
HUGGINGFACE_BASE_URL=https://api-inference.huggingface.co/models
PYTHON_EXECUTABLE=python3
SENTENCE_TRANSFORMERS_SCRIPT=./scripts/embed_query.py
SENTENCE_TRANSFORMERS_TIMEOUT_MS=120000

LLM_PROVIDER=sealion
SEALION_API_KEY=
